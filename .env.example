# Strix Consensus Server Configuration
# Copy this file to .env and customize

# ============================================
# OPERATING MODE
# ============================================
# Options: single, consensus
MODE=consensus

# Number of workers to use in consensus mode (1-5)
WORKER_COUNT=3

# Enable judge evaluation in consensus mode (true/false)
JUDGE_ENABLED=true

# ============================================
# MODELS - HuggingFace Repositories
# ============================================
# Format: username/model-name-GGUF
# The script will automatically download the quantized version

# Worker models (can be same or different)
WORKER_1_MODEL=unsloth/Llama-3.1-8B-Instruct-GGUF
WORKER_2_MODEL=Qwen/Qwen2.5-7B-Instruct-GGUF
WORKER_3_MODEL=deepseek-ai/DeepSeek-Coder-V2-Lite-Instruct-GGUF
# WORKER_4_MODEL=microsoft/Phi-3-mini-4k-instruct-GGUF
# WORKER_5_MODEL=google/gemma-2-2b-it-GGUF

# Judge model (usually larger/better quality)
JUDGE_MODEL=unsloth/Llama-3.1-8B-Instruct-GGUF

# Quantization level
# Options: Q2_K, Q3_K_M, Q4_K_M, Q5_K_M, Q6_K, Q8_0
# Q4_K_M recommended for balance of speed/quality
QUANTIZATION=Q4_K_M

# ============================================
# GPU CONFIGURATION
# ============================================
# GPU backend: hip, cuda, vulkan, or cpu
GPU_BACKEND=hip

# Number of GPU layers to offload (0 = CPU only)
# -1 = all layers, auto-detect
N_GPU_LAYERS=-1

# ============================================
# PORTS
# ============================================
ORCHESTRATOR_PORT=8080
WEB_MANAGER_PORT=5000

# Starting port for workers (will use 8101, 8102, etc.)
WORKER_BASE_PORT=8101
JUDGE_PORT=8200

# ============================================
# PERFORMANCE
# ============================================
# Context size (tokens)
CONTEXT_SIZE=32768

# Batch size for processing
BATCH_SIZE=512

# Number of parallel sequences
N_PARALLEL=4

# Timeout for consensus (seconds)
CONSENSUS_TIMEOUT=120

# ============================================
# PATHS
# ============================================
# Where to store downloaded models
MODELS_DIR=./models

# Log directory
LOGS_DIR=./logs

# ============================================
# ADVANCED
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable Flash Attention (faster, less memory)
FLASH_ATTENTION=true

# Enable memory mapping (load models faster)
MMAP=true

# Lock model in memory (prevent swapping)
MLOCK=false
